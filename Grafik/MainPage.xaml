<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:Grafik.Controls"
             x:Class="Grafik.MainPage"
             Title="График"
             BackgroundColor="#1E1E1E">

    <AbsoluteLayout>
        <Grid RowDefinitions="Auto,*"
              AbsoluteLayout.LayoutBounds="0,0,1,1"
              AbsoluteLayout.LayoutFlags="All">
            
            <!-- Верхняя панель с индикатором -->
            <Grid Grid.Row="0" 
                  Padding="15,10" 
                  BackgroundColor="#2D2D2D"
                  ColumnDefinitions="*,Auto">
                
                <Label Grid.Column="0"
                       Text="📅 Расписание"
                       FontSize="18"
                       FontAttributes="Bold"
                       TextColor="White"
                       VerticalOptions="Center"/>
                
                <!-- Индикатор соединения -->
                <controls:ConnectionIndicator Grid.Column="1"/>
            </Grid>

            <!-- Основной контент -->
            <ScrollView Grid.Row="1">
                <StackLayout Padding="20" Spacing="15" x:Name="MainStackLayout">
                    <!-- Первая группа элементов (начальное состояние) -->
                    <StackLayout x:Name="FirstStepGroup">
                        <Label Text="Загрузи Excel файл расписания" 
                               FontSize="22" 
                               HorizontalOptions="Center" />
                        
                        <Label x:Name="Transp1" 
                               BackgroundColor="Transparent"/>

                        <Button Text="Загрузить EXCEL" 
                                Clicked="OnLoadExcelClicked"
                                HorizontalOptions="FillAndExpand"
                                BackgroundColor="#191968"
                                TextColor="White"/>
                    </StackLayout>

                    <!-- Вторая группа элементов (изначально скрыта) -->
                    <StackLayout x:Name="SecondStepGroup" IsVisible="False">
                        <Label x:Name="Instruction2" 
                               Text="Выбери сотрудника" 
                               FontSize="22" 
                               HorizontalOptions="Center"/>
                        
                        <Label x:Name="Transp2" 
                               BackgroundColor="Transparent"/>
                        
                        <Picker x:Name="EmployeePicker" 
                                SelectedIndexChanged="OnEmployeeSelected"
                                HorizontalOptions="FillAndExpand"/>
                        
                        <Label x:Name="Transp3" BackgroundColor="Transparent"/>

                        <Button x:Name="LoadSchedule" 
                                Text="Показать расписание" 
                                Clicked="LoadScheduleForEmployeer"
                                HorizontalOptions="FillAndExpand"
                                BackgroundColor="#191968"
                                TextColor="White"/>
                    </StackLayout>

                    <Label x:Name="MessageLabel" 
                           IsVisible="False"
                           HorizontalOptions="Center"
                           TextColor="Red"/>
                </StackLayout>
            </ScrollView>
        </Grid>

        <!-- Кнопка удаления (слева снизу) -->
        <Button x:Name="DeleteData"
                Text="🗑"
                FontSize="16"
                WidthRequest="50"
                HeightRequest="50"
                CornerRadius="25"
                BackgroundColor="DarkRed"
                TextColor="White"
                Clicked="DeleteAllFiles"
                AbsoluteLayout.LayoutBounds="10,1,50,50"
                AbsoluteLayout.LayoutFlags="YProportional" />

        <!-- Кнопка чата (центр снизу) -->
        <Button x:Name="ChatButton"
                Text="💬"
                FontSize="16"
                WidthRequest="50"
                HeightRequest="50"
                CornerRadius="25"
                BackgroundColor="#4CAF50"
                TextColor="White"
                Clicked="GoToChat"
                IsVisible="False"   
                AbsoluteLayout.LayoutBounds="0.5,1,50,50"
                AbsoluteLayout.LayoutFlags="XProportional,YProportional"/>

        <!-- Кнопка настроек (справа снизу) --> 
        <Button x:Name="SettingsButton"
                Text="⚙"
                FontSize="16"
                WidthRequest="50"
                HeightRequest="50"
                CornerRadius="25"
                BackgroundColor="#007ACC"
                TextColor="White"
                Clicked="GoToSettings"
                AbsoluteLayout.LayoutBounds="1,1,60,50"
                AbsoluteLayout.LayoutFlags="XProportional,YProportional" />

        <!-- Скрытые кнопки для тестирования -->
        <Button Text="Тест мгновенного уведомления" 
                Clicked="OnTestImmediateNotificationClicked"
                IsEnabled="False" 
                IsVisible="False"/>

        <Button Text="Тест планирования уведомления" 
                Clicked="OnTestScheduledNotificationClicked"
                IsEnabled="False" 
                IsVisible="False"/>
    </AbsoluteLayout>
</ContentPage>
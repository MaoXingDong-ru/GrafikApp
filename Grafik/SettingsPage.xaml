<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:Grafik.Controls"
             x:Class="Grafik.SettingsPage"
             Title="Настройки"
             BackgroundColor="#1E1E1E">

    <ScrollView Padding="20">
        <VerticalStackLayout Spacing="20">

            <!-- Заголовок с индикатором -->
            <Grid ColumnDefinitions="*,Auto">
                <Label Grid.Column="0"
                       Text="⚙️ Настройки"
                       FontSize="24"
                       FontAttributes="Bold"
                       TextColor="White"/>
                
                <controls:ConnectionIndicator Grid.Column="1"/>
            </Grid>

            <!-- Напоминание о смене -->
            <VerticalStackLayout Spacing="8">
                <Label Text="Напоминание о смене:" 
                       FontSize="16" 
                       FontAttributes="Bold"
                       TextColor="White"/>
                <Picker x:Name="ReminderPicker"
                        SelectedIndex="0"/>
            </VerticalStackLayout>

            <!-- Firebase интеграция -->
            <VerticalStackLayout Spacing="8">
                <Label Text="Firebase (чат):" 
                       FontSize="16" 
                       FontAttributes="Bold"
                       TextColor="White"/>

                <Frame BorderColor="#4CAF50" 
                       CornerRadius="8" 
                       Padding="12"
                       HasShadow="False">
                    <Label x:Name="FirebaseStatusLabel"
                           Text="○ Firebase не настроен"
                           FontSize="13"
                           TextColor="Orange"/>
                </Frame>

                <Label Text="Database URL (из Firebase Console):" 
                       FontSize="12"
                       TextColor="White"/>
                <Entry x:Name="FirebaseUrlEntry" 
                       Placeholder="https://your-project.firebaseio.com"/>

                <Label Text="Пример: https://grafikchat-abc123.firebaseio.com" 
                       FontSize="11"
                       TextColor="Gray"
                       Margin="0,-5,0,10"/>

                <Button Text="Проверить соединение Firebase"
                        Clicked="OnTestFirebaseClicked"
                        BackgroundColor="#4CAF50"
                        TextColor="White"
                        Padding="10"/>
            </VerticalStackLayout>

            <!-- Кнопка сохранения -->
            <Button x:Name="SaveButton"
                    Text="Сохранить"
                    Clicked="OnSaveSettingsClicked"
                    BackgroundColor="#2196F3"
                    TextColor="White"
                    Padding="10"/>

            <!-- Разделитель -->
            <BoxView Color="#DDDDDD" HeightRequest="1" Margin="0,10"/>

            <!-- Баг-репорты -->
            <VerticalStackLayout Spacing="8">
                <Label Text="Обратная связь:" 
                       FontSize="16" 
                       FontAttributes="Bold"
                       TextColor="White"/>

                <Label Text="Сообщите о найденных ошибках или предложите новый функционал" 
                       FontSize="12"
                       TextColor="Gray"/>

                <Button Text="🐛  Баг-репорты и предложения"
                        Clicked="OnBugReportClicked"
                        BackgroundColor="#F44336"
                        TextColor="White"
                        FontSize="15"
                        Padding="12"
                        CornerRadius="8"/>
            </VerticalStackLayout>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
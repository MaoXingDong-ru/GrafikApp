<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="GrafikAdmin.SwapRequestsPage"
             Title="Запросы на обмен"
             BackgroundColor="#1E1E1E">

    <Grid RowDefinitions="Auto,*">
        
        <!-- Заголовок -->
        <Frame Grid.Row="0"
               BackgroundColor="#2D2D2D"
               Padding="16"
               CornerRadius="0"
               HasShadow="False">
            <StackLayout>
                <Label Text="Запросы на обмен сменами"
                       FontSize="20"
                       FontAttributes="Bold"
                       TextColor="White"
                       HorizontalOptions="Center" />
                <Label x:Name="CountLabel"
                       Text="Загрузка..."
                       FontSize="14"
                       TextColor="#888888"
                       HorizontalOptions="Center" />
            </StackLayout>
        </Frame>

        <!-- Список запросов -->
        <RefreshView Grid.Row="1"
                     x:Name="RefreshViewControl"
                     Refreshing="OnRefreshing">
            <CollectionView x:Name="RequestsCollection"
                            Margin="16">
                <CollectionView.EmptyView>
                    <StackLayout VerticalOptions="Center"
                                 HorizontalOptions="Center"
                                 Padding="40">
                        <Label Text="✅" FontSize="60" HorizontalOptions="Center" />
                        <Label Text="Нет ожидающих запросов"
                               FontSize="18"
                               TextColor="#888888"
                               HorizontalOptions="Center" />
                    </StackLayout>
                </CollectionView.EmptyView>
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Frame Padding="16"
                               Margin="0,6"
                               CornerRadius="12"
                               BackgroundColor="#2D2D2D"
                               BorderColor="#3D3D3D"
                               HasShadow="False">
                            <StackLayout Spacing="12">
                                
                                <!-- Статус и дата -->
                                <Grid ColumnDefinitions="*,Auto">
                                    <Label Grid.Column="0"
                                           Text="{Binding StatusDisplay}"
                                           FontSize="16"
                                           FontAttributes="Bold"
                                           TextColor="{Binding StatusColor}" />
                                    <Label Grid.Column="1"
                                           Text="{Binding CreatedAtDisplay}"
                                           FontSize="12"
                                           TextColor="#888888"
                                           VerticalOptions="Center" />
                                </Grid>

                                <!-- Линия -->
                                <Frame BackgroundColor="#3D3D3D"
                                       Padding="6"
                                       CornerRadius="6"
                                       HasShadow="False">
                                    <Label Text="{Binding LineDisplay}"
                                           FontSize="12"
                                           TextColor="#AAAAAA"
                                           HorizontalOptions="Center" />
                                </Frame>

                                <!-- Информация об обмене -->
                                <Grid ColumnDefinitions="*,Auto,*" 
                                      RowDefinitions="Auto"
                                      ColumnSpacing="10">
                                    
                                    <!-- Инициатор (левая колонка) -->
                                    <StackLayout Grid.Column="0" Spacing="2">
                                        <Label Text="Отдаёт смену:"
                                               FontSize="11"
                                               TextColor="#888888" />
                                        <Label Text="{Binding RequesterName}"
                                               FontSize="14"
                                               FontAttributes="Bold"
                                               TextColor="White" />
                                        <Label Text="{Binding RequesterDateDisplay}"
                                               FontSize="13"
                                               TextColor="#64B5F6" />
                                        <Label Text="{Binding RequesterShift}"
                                               FontSize="12"
                                               TextColor="#64B5F6"
                                               FontAttributes="Bold" />
                                    </StackLayout>

                                    <!-- Стрелка (центр) -->
                                    <Label Grid.Column="1"
                                           Text="↔️"
                                           FontSize="24"
                                           VerticalOptions="Center"
                                           HorizontalOptions="Center" />

                                    <!-- Цель (правая колонка) -->
                                    <StackLayout Grid.Column="2" Spacing="2">
                                        <Label Text="Получает смену:"
                                               FontSize="11"
                                               TextColor="#888888" />
                                        <Label Text="{Binding TargetName}"
                                               FontSize="14"
                                               FontAttributes="Bold"
                                               TextColor="White" />
                                        <Label Text="{Binding TargetDateDisplay}"
                                               FontSize="13"
                                               TextColor="#FF8C00" />
                                        <Label Text="{Binding TargetShift}"
                                               FontSize="12"
                                               TextColor="#FF8C00"
                                               FontAttributes="Bold" />
                                    </StackLayout>
                                </Grid>

                                <!-- Разделитель -->
                                <BoxView HeightRequest="1" 
                                         Color="#3D3D3D" 
                                         IsVisible="{Binding IsPending}" />

                                <!-- Поле для комментария -->
                                <Entry x:Name="CommentEntry"
                                       Placeholder="Комментарий (необязательно)"
                                       PlaceholderColor="#666666"
                                       TextColor="White"
                                       BackgroundColor="#3D3D3D"
                                       IsVisible="{Binding IsPending}" />

                                <!-- Кнопки действий (только для pending) -->
                                <Grid ColumnDefinitions="*,*"
                                      ColumnSpacing="10"
                                      IsVisible="{Binding IsPending}">
                                    <Button Grid.Column="0"
                                            Text="✅ Одобрить"
                                            BackgroundColor="#4CAF50"
                                            TextColor="White"
                                            FontSize="14"
                                            HeightRequest="45"
                                            CornerRadius="8"
                                            CommandParameter="{Binding .}"
                                            Clicked="OnApproveClicked" />
                                    <Button Grid.Column="1"
                                            Text="❌ Отклонить"
                                            BackgroundColor="#F44336"
                                            TextColor="White"
                                            FontSize="14"
                                            HeightRequest="45"
                                            CornerRadius="8"
                                            CommandParameter="{Binding .}"
                                            Clicked="OnDenyClicked" />
                                </Grid>

                                <!-- Комментарий админа (для обработанных) -->
                                <Label Text="{Binding AdminComment, StringFormat='💬 {0}'}"
                                       FontSize="12"
                                       TextColor="#AAAAAA"
                                       IsVisible="{Binding IsProcessed}" />

                            </StackLayout>
                        </Frame>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </RefreshView>

    </Grid>
</ContentPage>
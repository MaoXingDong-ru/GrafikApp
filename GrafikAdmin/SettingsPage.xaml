<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:GrafikAdmin.Controls"
             x:Class="GrafikAdmin.SettingsPage"
             Title="Настройки"
             BackgroundColor="#1E1E1E">

    <ScrollView Padding="20">
        <VerticalStackLayout Spacing="20">

            <!-- Заголовок с индикатором -->
            <Grid ColumnDefinitions="*,Auto">
                <Label Grid.Column="0"
                       Text="⚙️ Настройки"
                       FontSize="24"
                       FontAttributes="Bold"
                       TextColor="White"/>
                
                <controls:ConnectionIndicator Grid.Column="1"/>
            </Grid>

            <!-- Firebase URL -->
            <Frame BackgroundColor="#2D2D2D" 
                   Padding="15" 
                   CornerRadius="10"
                   HasShadow="False">
                <VerticalStackLayout Spacing="10">
                    <Label Text="🔥 Firebase URL"
                           FontSize="16"
                           FontAttributes="Bold"
                           TextColor="White"/>
                    
                    <Entry x:Name="FirebaseUrlEntry"
                           Placeholder="https://your-project.firebasedatabase.app"
                           PlaceholderColor="Gray"
                           TextColor="White"
                           BackgroundColor="#3D3D3D"
                           Keyboard="Url"/>
                    
                    <Label x:Name="ConnectionStatus"
                           Text=""
                           FontSize="12"
                           TextColor="Gray"/>
                    
                    <Button Text="🔌 Проверить подключение"
                            BackgroundColor="#FF9800"
                            TextColor="White"
                            CornerRadius="8"
                            Clicked="OnTestConnectionClicked"/>
                </VerticalStackLayout>
            </Frame>

            <!-- Кнопка сохранения -->
            <Button Text="💾 Сохранить настройки"
                    BackgroundColor="#4CAF50"
                    TextColor="White"
                    FontSize="16"
                    HeightRequest="50"
                    CornerRadius="10"
                    Clicked="OnSaveClicked"/>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
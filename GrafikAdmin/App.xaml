<Application xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="GrafikAdmin.App">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/Styles/Colors.xaml" />
                <ResourceDictionary Source="Resources/Styles/Styles.xaml" />
            </ResourceDictionary.MergedDictionaries>
            
            <!-- Тёмная тема -->
            <Color x:Key="PageBackgroundColor">#1E1E1E</Color>
            <Color x:Key="CardBackgroundColor">#2D2D2D</Color>
            <Color x:Key="HeaderBackgroundColor">#3D3D3D</Color>
            <Color x:Key="PrimaryTextColor">#FFFFFF</Color>
            <Color x:Key="SecondaryTextColor">#B0B0B0</Color>
            <Color x:Key="AccentColor">#1976D2</Color>
            
            <!-- Цвета кнопок -->
            <Color x:Key="BlueButtonColor">#2196F3</Color>
            <Color x:Key="GreenButtonColor">#4CAF50</Color>
            <Color x:Key="OrangeButtonColor">#FF9800</Color>
            <Color x:Key="PurpleButtonColor">#9C27B0</Color>
            <Color x:Key="GrayButtonColor">#607D8B</Color>
            
        </ResourceDictionary>
    </Application.Resources>
</Application>
